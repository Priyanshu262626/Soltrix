# =========================================================================
# JutaHindustani - Root .gitignore
# =========================================================================

# -------------------------------------------------------------------------
# Node / Frontend (React + Vite)
# -------------------------------------------------------------------------
# Dependencies
node_modules/
**/node_modules/

# Production / Build outputs
dist/
dist-ssr/
**/dist/
**/dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment and Local Config files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Vite and ESLint temp files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.eslintcache

# -------------------------------------------------------------------------
# Java / Spring Boot (Maven)
# -------------------------------------------------------------------------
# Compiled class files
*.class

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven build directory
target/
**/target/

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Virtual machine crash logs
hs_err_pid*
replay_pid*

# Maven wrapper downloads (but track wrapper properties and jar)
.mvn/wrapper/maven-wrapper.jar
!**/wrapper/maven-wrapper.properties
!**/wrapper/maven-wrapper.jar

# -------------------------------------------------------------------------
# IDEs, Editors, and OS Files
# -------------------------------------------------------------------------
# JetBrains (IntelliJ IDEA, WebStorm, etc.)
.idea/
*.iws
*.iml
*.ipr
**/*.iml

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Eclipse
.metadata
.classpath
.project
.settings/

# Sublime Text / NetBeans / Other
*.sublime-workspace
nbproject/
build/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
